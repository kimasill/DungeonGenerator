# Visual Studio user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Unreal Engine cache and temporary files
Binaries/*
Plugins/**/Binaries/*
Build/*
Intermediate/*
Plugins/**/Intermediate/*
DerivedDataCache/*
Saved/*

# Whitelist some Build files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# Unreal Engine asset files (binary files that are large)
*.uasset
*.umap
*.ubulk
*.uexp
#
# --- Allowlist for PCG assets (track these despite global ignores) ---
!Content/PCG/**/*.uasset
!Content/PCG/**/*.umap
!Content/PCG/**/*.ubulk
!Content/PCG/**/*.uexp
!Content/PCG/*

# Built data for maps
*_BuiltData.uasset

# Starter Content (usually large and not needed in version control)
Content/StarterContent/**
Content/Examples/**
Content/Assets/**

# External actors (World Partition)
Content/**/__ExternalActors__/**
Content/**/__ExternalObjects__/**

# HLOD files
*_HLODLayer_*.uasset

# Landscape cache
Content/**/LandscapeGrassOutput_*.uasset

# Audio files (can be large)
*.wav
*.ogg

# Texture files (can be large)
*.tga
*.png
*.jpg
*.jpeg
*.bmp
*.dds

# Video files
*.mp4
*.avi
*.mov

# Mesh files
*.fbx
*.obj
*.3ds
*.max

# Temporary files
*.tmp
*.temp
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
